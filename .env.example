# Prefer refreshToken over storing Tonal passwords in hosting env vars.
# Generate each refresh token locally with:
# npm run auth:token -- member@example.com tonal-password
TONAL_MEMBERS_JSON='[
  {"id":"you","name":"You","refreshToken":"v1.example"},
  {"id":"partner","name":"Partner","refreshToken":"v1.example"}
]'

# Optional member avatar uploads. Create a Vercel Blob store and set these
# server-side values in local/Vercel env vars before using /#minda.
BLOB_READ_WRITE_TOKEN=""
AVATAR_ADMIN_TOKEN=""
